# ============================================================
#  MusicVoting — Deployment-Konfiguration
#
#  1. Diese Datei nach  .env  kopieren:   cp .env.example .env
#  2. Alle REPLACE_ME_*-Werte ersetzen (siehe PLACEHOLDERS.md).
#  Das ist die EINZIGE Datei, in der ihr etwas anpassen müsst.
# ============================================================

# --- Domain (Pflicht) -------------------------------------------------
# Eure (Sub-)Domain OHNE "https://" und ohne abschließenden Slash.
# Beispiel:  party.htl-leonding.ac.at
DOMAIN=REPLACE_ME_DOMAIN

# E-Mail für das Let's-Encrypt-TLS-Zertifikat (erhält nur Ablauf-Warnungen).
ACME_EMAIL=REPLACE_ME_EMAIL

# --- Spotify (Pflicht) ------------------------------------------------
# Aus dem Spotify Developer Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=REPLACE_ME_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=REPLACE_ME_SPOTIFY_CLIENT_SECRET

# --- Datenbank (kann so bleiben) --------------------------------------
# Nur ändern, wenn ihr ein eigenes DB-Passwort wollt.
POSTGRES_DB=musicvoting
POSTGRES_USER=musicvoting
POSTGRES_PASSWORD=musicvoting

# --- Optional ---------------------------------------------------------
# Markt (ISO-Land) für "ähnliche Songs" beim Auffüllen der leeren Queue.
SPOTIFY_MARKET=AT
# Öffentliche, NUTZER-eigene Playlist-ID als Fallback für die leere Queue.
# Leer lassen = Fallback aus. (Spotify-eigene 37i9...-Playlists funktionieren NICHT.)
SPOTIFY_TOPCHARTS_PLAYLIST_ID=
